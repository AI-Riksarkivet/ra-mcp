{
  "name": "pdf-viewer",
  "version": "0.1.0",
  "type": "module",
  "description": "PDF Viewer - Interactive PDF rendering with PDF.js, search, and annotations",
  "scripts": {
    "build": "tsc --noEmit && cross-env INPUT=mcp-app.html vite build",
    "build:watch": "cross-env INPUT=mcp-app.html vite build --watch",
    "dev": "cross-env NODE_ENV=development cross-env INPUT=mcp-app.html vite build --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "pdfjs-dist": "^5.0.0",
    "svelte": "^5.55.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@types/node": "22.10.0",
    "cross-env": "^10.1.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
